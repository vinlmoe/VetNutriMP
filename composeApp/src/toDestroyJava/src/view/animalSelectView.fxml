<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" stylesheets="@application.css" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AnimalSelectorControler">
   <children>
      <BorderPane prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <bottom>
            <ButtonBar fx:id="baseButtonBar" prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
              <buttons>
                  <Button mnemonicParsing="false" onAction="#cancel" text="%Cancel" />
                  <Button fx:id="openAnimButton" mnemonicParsing="false" onAction="#validate" text="%openAnimal" />
              </buttons>
            </ButtonBar>
         </bottom>
         <top>
            <HBox BorderPane.alignment="CENTER">
               <children>
                  <TextField fx:id="searchText" promptText="%search" />
                  <ComboBox fx:id="speciesCombo" prefWidth="150.0" />
               </children>
            </HBox>
         </top>
         <center>
            <TableView fx:id="animTable" prefHeight="200.0" prefWidth="377.0" BorderPane.alignment="CENTER">
               <columns>
                  <TableColumn fx:id="specieColumn" prefWidth="75.0" text="%specie" />
                  <TableColumn fx:id="breedColumn" prefWidth="75.0" text="%breed" />
                  <TableColumn fx:id="animalNameColumn" prefWidth="75.0" text="%animalName" />
                  <TableColumn fx:id="ownerNameColumn" prefWidth="75.0" text="%ownerName" />
                  <TableColumn fx:id="idColumn" prefWidth="75.0" text="%id" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
