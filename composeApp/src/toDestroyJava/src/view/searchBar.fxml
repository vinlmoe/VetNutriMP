<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<Accordion fx:id="mainAccord" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="1000.0" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FoodSearchController">
   <panes>
      <TitledPane fx:id="basicTitled" animated="false" text="%basic_search">
         <content>
            <GridPane prefHeight="70.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <ComboBox fx:id="dataCombo" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <TextField fx:id="searchText" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <ComboBox fx:id="speciesCombo" prefWidth="150.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                  <ComboBox fx:id="indicCombo" prefWidth="150.0" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                  <ComboBox fx:id="priceCombo" prefWidth="150.0" GridPane.columnIndex="5" GridPane.rowIndex="1" />
                  <ComboBox fx:id="typeCombo" prefWidth="150.0" GridPane.columnIndex="6" GridPane.rowIndex="1" />
                  <Label text="%Database" />
                  <Label text="%SearchField" GridPane.columnIndex="2" />
                  <Label text="%specie" GridPane.columnIndex="3" />
                  <Label text="%Indications" GridPane.columnIndex="4" />
                  <Label text="%mainSaleLocation" GridPane.columnIndex="5" />
                  <Label text="%Family" GridPane.columnIndex="6" />
                  <CheckBox fx:id="checkIncDeprecated" mnemonicParsing="false" text="%inc_deprecated" GridPane.columnIndex="7" GridPane.rowIndex="1" />
                  <Label text="%typeAlim" GridPane.columnIndex="1" />
                  <ComboBox fx:id="comboDB" prefWidth="150.0" GridPane.rowIndex="1" />
               </children>
            </GridPane>
         </content>
      </TitledPane>
      <TitledPane animated="false" expanded="false" text="%advance_search">
         <content>
            <BorderPane prefHeight="200.0" prefWidth="200.0">
               <center>
                  <TableView fx:id="constrainTable" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                     <columns>
                        <TableColumn fx:id="kindColumn_constrainTable" prefWidth="75.0" text="%kindConst" />
                        <TableColumn fx:id="conditionColumn_constrainTable" prefWidth="75.0" text="%constrain" />
                        <TableColumn fx:id="valueColumn_constrainTable" prefWidth="75.0" text="%value" />
                        <TableColumn fx:id="unitColumn_constrainTable" prefWidth="75.0" text="%unit" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </center>
               <bottom>
                  <ButtonBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                     <buttons>
                        <Button fx:id="addConditionButton" mnemonicParsing="false" onAction="#addConstrain" text="%add_constrain" />
                        <Button mnemonicParsing="false" onAction="#removeConstrain" text="%remove_constrain" />
                     </buttons>
                  </ButtonBar>
               </bottom>
            </BorderPane>
         </content>
      </TitledPane>
   </panes>
</Accordion>
