<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="200.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TargetEditorControler">
   <children>
      <BorderPane prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <center>
            <TableView fx:id="coefTable" BorderPane.alignment="CENTER">
               <columns>
                  <TableColumn fx:id="nameColumn" prefWidth="75.0" sortable="false" text="%Target" />
                  <TableColumn fx:id="valueColumn" prefWidth="75.0" sortable="false" text="%Value" />
                  <TableColumn fx:id="unitColumn" prefWidth="75.0" sortable="false" text="%Unit" />
                  <TableColumn fx:id="percentColumn" prefWidth="75.0" sortable="false" text="%percentEnd" />
                  <TableColumn fx:id="measureColumn" prefWidth="75.0" sortable="false" text="%baseMeasure" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </center>
         <right>
            <VBox BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="addButton" mnemonicParsing="false" onAction="#up" prefHeight="200.0" style="-fx-pref-width: 1em;" text="+" />
                  <Button blendMode="SRC_ATOP" mnemonicParsing="false" onAction="#down" prefHeight="200.0" style="-fx-pref-width: 1em;" text="-" textAlignment="CENTER" wrapText="true" />
               </children>
            </VBox>
         </right>
      </BorderPane>
   </children>
</AnchorPane>
