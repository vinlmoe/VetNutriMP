<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TableRecipeController">
   <children>
      <TableView fx:id="refTable" prefHeight="800.0">
         <columns>
            <TableColumn fx:id="speciesColumn" prefWidth="75.0" text="%specie" />
            <TableColumn fx:id="nameColumn" prefWidth="75.0" text="%name" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</VBox>
